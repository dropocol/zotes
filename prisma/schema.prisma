generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PrayerType {
  FAJR
  ZOHAR
  ASR
  MAGHRIB
  ISHA
  JUMAH
}

enum PrayerStatus {
  YES
  NO
  QAZAA
}

// Auth.js User model
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // Hashed with bcrypt
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  projects              Project[]
  notes                 Note[]
  todoLists             TodoList[]
  todoItems             TodoItem[]
  projectCollaborations ProjectCollaborator[]
  prayerRecords         PrayerRecord[]

  @@map("users")
}

// Required for Auth.js adapter
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Required for Auth.js adapter
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Required for Auth.js adapter
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Projects for organizing work
model Project {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  color       String?  @db.VarChar(7) // Hex color
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes          Note[]
  todoLists      TodoList[]
  collaborators  ProjectCollaborator[]

  @@index([userId])
  @@map("projects")
}

// Project collaborators for sharing access
model ProjectCollaborator {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("collaborator") // admin, collaborator
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_collaborators")
}

// Notes - the core content type
model Note {
  id          String    @id @default(cuid())
  title       String    @db.VarChar(500)
  content     String?   @db.Text // Stored as markdown
  projectId   String?   @map("project_id")
  userId      String    @map("user_id")
  pinned      Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@map("notes")
}

// Todo Lists - containers for todo items
model TodoList {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectId   String?  @map("project_id")
  userId      String   @map("user_id")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   TodoItem[]

  @@index([projectId])
  @@index([userId])
  @@map("todo_lists")
}

// Todo Items - individual tasks with sub-item support (one level only)
model TodoItem {
  id         String    @id @default(cuid())
  title      String
  notes      String?   @db.Text // Rich text notes
  status     String    @default("todo") // todo, in-progress, done
  priority   String    @default("medium") // low, medium, high, urgent
  dueDate    DateTime? @map("due_date")
  order      Int       @default(0)
  parentId   String?   @map("parent_id") // For sub-items (one level only)
  todoListId String    @map("todo_list_id")
  userId     String    @map("user_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  parent   TodoItem?  @relation("SubItems", fields: [parentId], references: [id], onDelete: Cascade)
  subItems TodoItem[] @relation("SubItems")
  todoList TodoList   @relation(fields: [todoListId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([todoListId])
  @@index([userId])
  @@index([parentId])
  @@map("todo_items")
}

// Prayer Records - track daily prayer completion
model PrayerRecord {
  id        String       @id @default(cuid())
  date      DateTime     @db.Date
  prayer    PrayerType
  status    PrayerStatus @default(NO)
  userId    String       @map("user_id")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, prayer])
  @@index([userId])
  @@index([date])
  @@map("prayer_records")
}
