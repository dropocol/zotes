generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PrayerType {
  FAJR
  ZOHAR
  ASR
  MAGHRIB
  ISHA
  JUMAH
}

enum PrayerStatus {
  YES
  NO
  QAZAA
}

enum JobSource {
  LINKEDIN
  SLACK
  FACEBOOK
  X
  COMPANY_WEBSITE
  REFERRAL
  JOB_BOARD
  OTHER
}

enum ApplicationMethod {
  EMAIL
  WEB_PORTAL
  LINKEDIN_EASY_APPLY
  REFERRAL
}

enum JobApplicationStatus {
  SAVED        // Found but not applied yet
  APPLIED      // Submitted application
  PHONE_SCREEN // Initial phone call scheduled
  INTERVIEW    // In interview process
  OFFER        // Received offer
  REJECTED     // Declined
  WITHDRAWN    // Withdrew application
  NO_RESPONSE  // Applied, no response
}

enum ResponseStatus {
  YES
  NO
  PENDING
}

enum InterviewType {
  PHONE
  VIDEO
  ONSITE
  TECHNICAL
  BEHAVIORAL
  FINAL
}

enum LeadType {
  COLD_EMAIL
  JOB
  REFERRAL
  NETWORKING
  RECRUITER
  AGENCY
}

enum LeadStatus {
  NEW
  REACHED_OUT
  REPLIED
  IN_CONVERSATION
  MEETING_SCHEDULED
  NOT_INTERESTED
  UNRESPONSIVE
}

// Auth.js User model
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // Hashed with bcrypt
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  projects              Project[]
  notes                 Note[]
  todoLists             TodoList[]
  todoItems             TodoItem[]
  projectCollaborations ProjectCollaborator[]
  prayerRecords         PrayerRecord[]
  recurringCompletions  RecurringCompletion[]
  jobApplications       JobApplication[]
  leads                 Lead[]

  @@map("users")
}

// Required for Auth.js adapter
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Required for Auth.js adapter
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Required for Auth.js adapter
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Projects for organizing work
model Project {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  color       String?  @db.VarChar(7) // Hex color
  order       Int      @default(0)
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes          Note[]
  todoLists      TodoList[]
  collaborators  ProjectCollaborator[]

  @@index([userId])
  @@map("projects")
}

// Project collaborators for sharing access
model ProjectCollaborator {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("collaborator") // admin, collaborator
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_collaborators")
}

// Notes - the core content type
model Note {
  id          String    @id @default(cuid())
  title       String    @db.VarChar(500)
  content     String?   @db.Text // Stored as markdown
  projectId   String?   @map("project_id")
  userId      String    @map("user_id")
  pinned      Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@map("notes")
}

// Todo Lists - containers for todo items
model TodoList {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectId   String?  @map("project_id")
  userId      String   @map("user_id")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   TodoItem[]

  @@index([projectId])
  @@index([userId])
  @@map("todo_lists")
}

// Todo Items - individual tasks with sub-item support (one level only)
model TodoItem {
  id         String    @id @default(cuid())
  title      String
  notes      String?   @db.Text // Rich text notes
  status     String    @default("todo") // todo, in-progress, done
  priority   String    @default("medium") // low, medium, high, urgent
  dueDate    DateTime? @map("due_date")
  order      Int       @default(0)
  parentId   String?   @map("parent_id") // For sub-items (one level only)
  todoListId String    @map("todo_list_id")
  userId     String    @map("user_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Recurrence fields
  isRecurring     Boolean   @default(false) @map("is_recurring")
  frequency       String?   // DAILY, WEEKLY, MONTHLY, CUSTOM
  daysOfWeek      String?   @map("days_of_week") @db.Text // JSON [0,1,2,3,4,5,6]
  recurrenceStart DateTime? @map("recurrence_start")
  recurrenceEnd   DateTime? @map("recurrence_end")

  parent      TodoItem?             @relation("SubItems", fields: [parentId], references: [id], onDelete: Cascade)
  subItems    TodoItem[]            @relation("SubItems")
  todoList    TodoList              @relation(fields: [todoListId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions RecurringCompletion[]

  @@index([todoListId])
  @@index([userId])
  @@index([parentId])
  @@map("todo_items")
}

// Prayer Records - track daily prayer completion
model PrayerRecord {
  id        String       @id @default(cuid())
  date      DateTime     @db.Date
  prayer    PrayerType
  status    PrayerStatus @default(NO)
  userId    String       @map("user_id")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, prayer])
  @@index([userId])
  @@index([date])
  @@map("prayer_records")
}

// Recurring Completion - track daily completion status for recurring todos
model RecurringCompletion {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  status     String   @default("todo") // todo, done, skipped
  todoItemId String   @map("todo_item_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  todoItem TodoItem @relation(fields: [todoItemId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, todoItemId])
  @@index([userId])
  @@index([date])
  @@map("recurring_completions")
}

// Job Application - track job hunting progress
model JobApplication {
  id                String                @id @default(cuid())
  jobTitle          String                @map("job_title")
  companyName       String                @map("company_name")
  source            JobSource
  applicationMethod ApplicationMethod     @map("application_method")
  jobPostingUrl     String?               @map("job_posting_url")
  salaryMin         Int?                  @map("salary_min")
  salaryMax         Int?                  @map("salary_max")
  salaryCurrency    String?               @default("USD") @map("salary_currency")
  location          String?
  isRemote          Boolean               @default(false) @map("is_remote")
  status            JobApplicationStatus  @default(SAVED)
  responseReceived  ResponseStatus        @default(PENDING) @map("response_received")
  notes             String?               @db.Text // Rich text HTML
  dateFound         DateTime?             @map("date_found") @db.Date
  dateApplied       DateTime?             @map("date_applied") @db.Date
  userId            String                @map("user_id")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviews JobInterview[]

  @@index([userId])
  @@index([status])
  @@map("job_applications")
}

// Job Interview - track interview details for job applications
model JobInterview {
  id               String        @id @default(cuid())
  jobApplicationId String        @map("job_application_id")
  interviewType    InterviewType @map("interview_type")
  roundNumber      Int           @map("round_number")
  scheduledAt      DateTime?     @map("scheduled_at")
  completedAt      DateTime?     @map("completed_at")
  notes            String?       @db.Text
  location         String?
  interviewerNames String?       @map("interviewer_names")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@index([jobApplicationId])
  @@index([scheduledAt])
  @@map("job_interviews")
}

// Lead - track networking contacts during job hunt
model Lead {
  id          String     @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  title       String?
  linkedinUrl String?    @map("linkedin_url") @db.Text
  notes       String?    @db.Text
  type        LeadType   @default(COLD_EMAIL)
  status      LeadStatus @default(NEW)
  userId      String     @map("user_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("leads")
}
